# Tavus CVI Configuration
# Copy this file to .env and fill in your credentials

# Required: Tavus API key from https://platform.tavus.io
TAVUS_API_KEY=

# Required: Persona ID (created via API or Tavus dashboard)
TAVUS_PERSONA_ID=

# Required: Replica ID (select from Tavus replica gallery)
TAVUS_REPLICA_ID=

# Optional: Server port (default 3100)
PORT=3100

# Optional: Allowed origin for CORS (default http://localhost:3100)
ALLOWED_ORIGIN=http://localhost:3100
