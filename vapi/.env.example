# ─── VAPI Platform ───
VAPI_API_KEY=                           # Your VAPI API key (from dashboard.vapi.ai)
VAPI_OUTBOUND_PHONE_NUMBER_ID=          # Phone number ID from VAPI dashboard (for outbound calls)
VAPI_WEBHOOK_URL=                       # Full webhook URL, e.g. https://your-domain.vercel.app/api/vapi/webhook

# ─── Application ───
NEXT_PUBLIC_BASE_URL=                   # Your deployment URL (Vercel, etc.)
SETUP_SECRET=                           # Secret for the /api/vapi/setup endpoint
PORT=3000                               # Server port (standalone mode)

# ─── Practice ───
PRACTICE_TRANSFER_NUMBER=+14078779003   # Orlando Family Dentistry office line

# ─── Provider Keys (set in VAPI Dashboard → Provider Keys, NOT here) ───
# OPENAI_API_KEY      → Set in VAPI dashboard
# DEEPGRAM_API_KEY    → Set in VAPI dashboard
# RIME_API_KEY        → Set in VAPI dashboard
