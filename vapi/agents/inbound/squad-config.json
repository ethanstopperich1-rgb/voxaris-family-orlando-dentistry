{
  "name": "Family Orlando Dentistry — Inbound Squad",
  "members": [
    {
      "assistant": {
        "name": "FOD Receptionist",
        "firstMessage": "Hi, thanks for calling Family Orlando Dentistry. How can I help you today?",
        "model": {
          "provider": "openai",
          "model": "gpt-4o-mini",
          "temperature": 0.4,
          "systemPrompt": "{{file:prompts/receptionist.txt}}"
        },
        "voice": {
          "provider": "rime",
          "voiceId": "marsh"
        },
        "transcriber": {
          "provider": "deepgram",
          "model": "nova-2",
          "language": "en"
        },
        "serverUrl": "{{VAPI_SERVER_URL}}/api/tool-call",
        "serverUrlSecret": "{{VAPI_WEBHOOK_SECRET}}"
      },
      "assistantDestinations": [
        {
          "type": "assistant",
          "assistantName": "FOD Invisalign Qualifier",
          "message": "I'm going to connect you with our Invisalign specialist.",
